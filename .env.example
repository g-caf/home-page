# Environment Variables Template
# Copy this file to .env for local development

# Node environment (development or production)
NODE_ENV=development

# Server port
PORT=3000

# Database URL (only needed for PostgreSQL)
# For local development, leave empty to use SQLite
# For production (Render), this will be auto-set by Render
# DATABASE_URL=postgresql://user:password@host:5432/database

# Logging level (optional)
LOG_LEVEL=info

# Writing submissions admin endpoints (HTTP Basic Auth)
# /admin/writing-submissions and /admin/writing-submissions.csv
# ADMIN_USERNAME=change-me
# ADMIN_PASSWORD=change-me
# Optional comma-separated allowlist (example: 127.0.0.1,::1)
# ADMIN_ALLOWED_IPS=
